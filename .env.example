NODE_ENV=development
PORT=80
HOST=0.0.0.0
SERVER_URL=http://localhost
CORS_ORIGINS=*

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=whatsapp
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/whatsapp

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379
LOG_LEVEL=info

JWT_SECRET=change-this-to-a-long-random-secret-with-at-least-32-characters
JWT_ISSUER=whatsapp-bot-api
JWT_AUDIENCE=whatsapp-bot-clients
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN_DAYS=30

# Seed safety (keep false in production)
ALLOW_PRISMA_SEED_IN_PRODUCTION=false
