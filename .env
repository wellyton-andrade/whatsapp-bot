# server configuration
NODE_ENV=development
PORT=3000
HOST=localhost
SERVER_URL=http://localhost:3000
CORS_ORIGINS=*

# database configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=admin
DB_PASSWORD=1234
DB_NAME=whatsapp_bot
DATABASE_URL=postgresql://admin:1234@localhost:5432/whatsapp_bot

# redis configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# auth configuration
JWT_SECRET=supersecretjwtkeywithatleast32chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN_DAYS=30